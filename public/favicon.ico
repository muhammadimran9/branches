<svg width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="32" height="32" rx="6" fill="#0f2b3d"/>
  
  <!-- Building icon -->
  <g transform="translate(6, 8)">
    <!-- Main building -->
    <rect x="0" y="8" width="12" height="15" fill="#60a5fa"/>
    <!-- Windows -->
    <rect x="1" y="9" width="2" height="2" fill="#ffffff"/>
    <rect x="4" y="9" width="2" height="2" fill="#ffffff"/>
    <rect x="7" y="9" width="2" height="2" fill="#ffffff"/>
    <rect x="10" y="9" width="2" height="2" fill="#ffffff"/>
    
    <rect x="1" y="12" width="2" height="2" fill="#ffffff"/>
    <rect x="4" y="12" width="2" height="2" fill="#ffffff"/>
    <rect x="7" y="12" width="2" height="2" fill="#ffffff"/>
    <rect x="10" y="12" width="2" height="2" fill="#ffffff"/>
    
    <rect x="1" y="15" width="2" height="2" fill="#ffffff"/>
    <rect x="4" y="15" width="2" height="2" fill="#ffffff"/>
    <rect x="7" y="15" width="2" height="2" fill="#ffffff"/>
    <rect x="10" y="15" width="2" height="2" fill="#ffffff"/>
    
    <!-- Door -->
    <rect x="5" y="19" width="2" height="4" fill="#ffffff"/>
  </g>
  
  <!-- Location pin -->
  <g transform="translate(22, 10)">
    <circle cx="3" cy="3" r="2.5" fill="#60a5fa"/>
    <circle cx="3" cy="3" r="1" fill="#ffffff"/>
    <path d="M3,5.5 C3,5.5 3,7 3,7" stroke="#60a5fa" stroke-width="1" fill="none"/>
  </g>
</svg>
